{
  "manifest_version": 3,
  "name": "Galaxus Virtual Try-On",
  "version": "1.0.0",
  "description": "Try on garments from any Galaxus product page. Drop your photo in the side panel and get a virtual try-on powered by FLUX.",
  "permissions": ["sidePanel", "tabs", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:5056/*",
    "https://*.galaxus.ch/*",
    "https://*.galaxus.de/*",
    "https://*.galaxus.at/*",
    "https://*.galaxus.fr/*",
    "https://*.galaxus.it/*",
    "https://*.galaxus.nl/*",
    "https://*.galaxus.be/*",
    "https://*.galaxus.lu/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Galaxus Virtual Try-On",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.galaxus.ch/*",
        "https://*.galaxus.de/*",
        "https://*.galaxus.at/*",
        "https://*.galaxus.fr/*",
        "https://*.galaxus.it/*",
        "https://*.galaxus.nl/*",
        "https://*.galaxus.be/*",
        "https://*.galaxus.lu/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
